# Self-Healing Ops - Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# -- LLM API Configuration ---------------------------------------------------

# Base URL for the LLM API (Anthropic-compatible endpoint)
MIMO_BASE_URL=https://api.anthropic.com

# LLM Model name
LLM_MODEL=claude-3-5-sonnet-20241022

# -- Agent API Keys ----------------------------------------------------------
# Each agent uses a separate API Key (simulating different service accounts /
# quota tiers in a real production environment).
# You can use the same key for all agents if you only have one.

MONITOR_API_KEY=your-monitor-api-key-here
DIAGNOSTIC_API_KEY=your-diagnostic-api-key-here
REPAIR_API_KEY=your-repair-api-key-here

# -- Agent Ports (optional, defaults shown) -----------------------------------
MONITOR_PORT=9101
DIAGNOSTIC_PORT=9102
REPAIR_PORT=9103
COORDINATOR_PORT=9200

# -- Other -------------------------------------------------------------------
INCIDENT_LOG_PATH=incidents.jsonl